# App
APP_NAME="Toko Web Jaya"
APP_ENV=development                        # development | production
SECRET_KEY=change-this-to-a-very-secret-random-string-in-production
BASE_URL=http://localhost:7777

# Database — used by docker-compose (db service) AND app (DATABASE_URL)
POSTGRES_USER=openpg
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=tokowebjaya
# Inside Docker: host = "db" (service name). For local tools: use localhost:5433
DATABASE_URL=postgresql://openpg:change-this-password@db:5432/tokowebjaya

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:7777/auth/google/callback

# Redis (inside Docker: host = redis service name on external network)
REDIS_URL=redis://rocdesk_redis:6379/0

# Email SMTP — Sumopod (smtp.sumopod.com port 465 SSL)
# Create credentials at: Sumopod Dashboard → Credentials → Create Credential
# Use credentials tied to your custom domain, NOT the default account credentials
SMTP_HOST=smtp.sumopod.com
SMTP_PORT=465
SMTP_USER=your-sumopod-smtp-username
SMTP_PASSWORD=your-sumopod-smtp-password
SMTP_FROM=no-reply@yourdomain.com
EMAIL_FROM=Toko Web Jaya <no-reply@yourdomain.com>

# File Storage
UPLOAD_DIR=static/uploads
MAX_UPLOAD_SIZE_MB=100

# Payment - Duitku
DUITKU_MERCHANT_CODE=your-duitku-merchant-code
DUITKU_API_KEY=your-duitku-api-key
DUITKU_CALLBACK_URL=http://localhost:7777/checkout/callback/duitku
DUITKU_BASE_URL=https://api-sandbox.duitku.com   # sandbox; change to production URL when live

# Payment - Mayar.id
MAYAR_API_KEY=your-mayar-api-key
MAYAR_CALLBACK_URL=http://localhost:7777/checkout/callback/mayar
MAYAR_BASE_URL=https://api.mayar.id
