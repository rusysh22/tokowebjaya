# App
APP_NAME="Toko Web Jaya"
APP_ENV=development
SECRET_KEY=change-this-to-a-very-secret-random-string-in-production
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tokowebjaya

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Redis
REDIS_URL=redis://localhost:6379/0

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@tokowebjaya.com

# File Storage
UPLOAD_DIR=static/uploads
MAX_UPLOAD_SIZE_MB=100

# Payment - Duitku
DUITKU_MERCHANT_CODE=your-duitku-merchant-code
DUITKU_API_KEY=your-duitku-api-key
DUITKU_CALLBACK_URL=http://localhost:8000/checkout/callback/duitku
DUITKU_BASE_URL=https://sandbox.duitku.com/webapi/api

# Payment - Mayar.id
MAYAR_API_KEY=your-mayar-api-key
MAYAR_CALLBACK_URL=http://localhost:8000/checkout/callback/mayar
MAYAR_BASE_URL=https://api.mayar.id
